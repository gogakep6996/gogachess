# =====================================================================
# gogachess — пример переменных окружения.
# Скопируйте в .env (для локалки) или в .env.production (на сервере).
# =====================================================================

# ---------- База данных (PostgreSQL) ----------
# Локально: поднимите Postgres или используйте сервис (Neon / Supabase и т.д.).
DATABASE_URL="postgresql://gogachess:gogachess@localhost:5432/gogachess?schema=public"

# ---------- Безопасность ----------
# Случайная длинная строка (например, openssl rand -hex 32)
JWT_SECRET="change-me-to-a-long-random-string"
# Ключ для Server Actions Next.js (32 байта base64, `openssl rand -base64 32`).
# Без него после каждой пересборки клиенты со старым кешем падают с "Failed to find Server Action".
SERVER_ACTIONS_ENCRYPTION_KEY=""

# ---------- HTTP ----------
PORT=3000
# Полный публичный URL сайта (нужен для cookie/CORS/serverActions allowedOrigins).
# В продакшене: https://gogachess.ru   В локалке оставьте пустым.
SITE_URL=""

# ---------- WebRTC ICE ----------
# По умолчанию — публичный STUN от Google. Для прод-аудио добавьте свой TURN.
NEXT_PUBLIC_ICE_SERVERS='[{"urls":"stun:stun.l.google.com:19302"}]'
# Пример с coturn:
# NEXT_PUBLIC_ICE_SERVERS='[{"urls":"stun:stun.l.google.com:19302"},{"urls":["turn:turn.example.com:3478?transport=udp","turn:turn.example.com:3478?transport=tcp"],"username":"u","credential":"p"}]'
