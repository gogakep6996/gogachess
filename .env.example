# =====================================================================
# gogachess — пример переменных окружения.
# Скопируйте в .env (для локалки) или в .env.production (на сервере).
# =====================================================================

# ---------- База данных (PostgreSQL) ----------
# Локально: поднимите Postgres или используйте сервис (Neon / Supabase и т.д.).
DATABASE_URL="postgresql://gogachess:gogachess@localhost:5432/gogachess?schema=public"

# ---------- Безопасность ----------
# Случайная длинная строка (например, openssl rand -hex 32)
JWT_SECRET="change-me-to-a-long-random-string"
# Ключ для Server Actions Next.js (32 байта base64, `openssl rand -base64 32`).
# Без него после каждой пересборки клиенты со старым кешем падают с "Failed to find Server Action".
SERVER_ACTIONS_ENCRYPTION_KEY=""

# ---------- HTTP ----------
PORT=3000
# Полный публичный URL сайта (нужен для cookie/CORS/serverActions allowedOrigins).
# В продакшене: https://gogachess.ru   В локалке оставьте пустым.
SITE_URL=""

# ---------- WebRTC ICE ----------
# Fallback ICE-сервера, если основной канал (Socket.IO 'audio:get-ice-servers') не сработает.
# Можно оставить только STUN — в большинстве сетей этого хватает.
NEXT_PUBLIC_ICE_SERVERS='[{"urls":"stun:stun.l.google.com:19302"}]'

# ---------- Собственный TURN (coturn) ----------
# Обязательно, если вам нужно, чтобы аудио работало через мобильный интернет
# (4G/5G, Carrier-Grade NAT) и за корпоративными файрволлами.
#
# 1) TURN_SECRET — общий секрет coturn ↔ app-сервер.
#    Сервер приложения вычисляет HMAC-SHA1 от этого секрета и выдаёт клиенту
#    короткоживущие credentials (1 час). Coturn проверяет их этим же секретом.
#    Сгенерируйте длинной случайной строкой: `openssl rand -hex 32`.
TURN_SECRET=""
#
# 2) TURN_REALM — доменное имя (для отображения и совпадения с TLS-сертификатом).
#    На VPS это домен сайта, например gogachess.ru.
TURN_REALM="gogachess.ru"
#
# 3) TURN_EXTERNAL_IP — публичный IPv4 вашего VPS.
#    Узнать: `curl -s ifconfig.me` или в панели хостинга.
TURN_EXTERNAL_IP=""
#
# 4) TURN_HOST — как клиент должен обращаться к TURN. Обычно совпадает с TURN_REALM.
#    Должен резолвиться в TURN_EXTERNAL_IP.
TURN_HOST="gogachess.ru"
