{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "server/**/*.ts",
    "src/lib/socket-events.ts",
    "src/lib/fen.ts",
    "src/lib/piece.ts",
    "src/types/**/*.ts"
  ]
}
